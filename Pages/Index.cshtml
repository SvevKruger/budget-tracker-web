@page
@model IndexModel
@{
    ViewData["Title"] = "Budget Tracker";
}

<h1>Budget Tracker </h1>

<h2>Add Transaction</h2>

<form method="post">
    <div>
        <label>Description:</label>
        <input type="text" name="description" placeholder="eg, salary rent"/>
    </div>
    <div>
        <label>Amount:</label>
        <input type="number" name="amount" step="0.01" placeholder="eg. 1500 or -500"/>
    </div>
    <button type="submit">Add Transaction</button>
</form>

<h2>Summary</h2>

<div>
    <p>Balance: <strong>@Model.Balance</strong></p>
    <p>TotalIncome: <strong>@Model.TotalIncome</strong></p>
    <p>TotalExpenses: <strong>@Model.TotalExpenses</strong></p>
</div>

<h2>Transactions:</h2>

<table class="table table-striped">
    <thead>
    <tr>
        <th>Date</th>
        <th>Description</th>
        <th>Amount</th>
    </tr>
    </thead>
    <tbody>

    @for (int i = 0; i < Model.Descriptions.Count; i++)
    {
        <tr>
            <td>@Model.Dates[i]</td>
            <td>@Model.Descriptions[i]</td>
            <td>@Model.Amounts[i]</td>
        </tr>
    }
    </tbody>
</table>


<p>Welcome to your personal budget tracker! </p>